require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';
require_once '/usr/local/emhttp/plugins/diskviewer/include/diskviewer_api.php';

$cfg = @parse_plugin_cfg('diskviewer', true) ?: [];

// unraid's resolved theme first, cfg fallback (cfg can be empty when theme was never explicitly set)
$unraid_theme = (string)($GLOBALS['display']['theme'] ?? '');
if ($unraid_theme === '') {
    $dynamix_cfg  = @parse_ini_file('/boot/config/plugins/dynamix/dynamix.cfg', true);
    $unraid_theme = (string)($dynamix_cfg['display']['theme'] ?? '');
}
// tool only needs light vs dark, not the widget's four-theme tuning
$dvt_theme    = in_array($unraid_theme, ['black','white','azure','gray'], true) ? $unraid_theme : 'black';
$dvt_light    = in_array($dvt_theme, ['white', 'azure'], true);
$lightClass   = $dvt_light ? ' dvt-light' : '';
$themeClass   = ' dvt-theme-' . $dvt_theme;

$tool_config = [
    'dvToken'    => DiskViewerEndpoint::generateNonce(),
    'csrfToken'  => (string)($var['csrf_token'] ?? ''),
    'lightTheme' => $dvt_light,
];
$tool_config_json = json_encode($tool_config, JSON_UNESCAPED_SLASHES);
?>

<link rel="stylesheet" type="text/css" href="/plugins/diskviewer/css/tool.css">
<script>window.diskviewerToolConfig = <?= $tool_config_json ?>;</script>

<div class="dvt-wrapper<?= $themeClass . $lightClass ?>">

  <div class="dvt-panel">

    <div class="dvt-tab-panel" id="dvtPanelOverview">
      <div class="dvt-header">
        <div class="dvt-header__left">
          <img src="/plugins/diskviewer/img/diskviewer.png" class="dvt-header__icon" alt="">
          <div>
            <h2 class="dvt-header__title">Disk Viewer</h2>
            <span class="dvt-header__sub" id="dvt-subtitle"></span>
          </div>
        </div>
        <div class="dvt-header__right">
          <div class="dvt-header__icons">
            <a href="/Settings/DiskViewerSettings" title="Settings"><i class="fa fa-cog" aria-hidden="true"></i></a>
          </div>
        </div>
      </div>

      <div class="dvt-overview-disks" id="dvt-overview-disks">

      </div>
    </div>

  </div>

</div>

<script defer src="/plugins/diskviewer/js/diskviewer-tool.js"></script>

<script>

(function() {
    'use strict';
    function unlockAncestors() {
        var wrap = document.querySelector('.dvt-wrapper');
        if (!wrap) return;
        var vw = window.innerWidth || document.documentElement.clientWidth;
        var el = wrap.parentElement;
        while (el && el !== document.documentElement) {
            var cs = window.getComputedStyle(el);
            var mw = parseFloat(cs.maxWidth);
            if (!isNaN(mw) && mw > 0 && mw < vw) {
                el.style.setProperty('max-width', 'none', 'important');
            }
            el = el.parentElement;
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', unlockAncestors);
    } else {
        unlockAncestors();
    }
    window.addEventListener('resize', unlockAncestors);
})();
</script>
