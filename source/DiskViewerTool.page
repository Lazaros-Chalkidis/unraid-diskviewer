/* Disk Viewer -- Tool page (System Information).
   Standalone deep-status page, fully separate from the dashboard widget.
   Its own page / js (diskviewer-tool.js) / css (tool.css). The shared data
   layer is diskviewer_api.php, reached via ?action= routes the same way the
   widget polls it. */

require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';
require_once '/usr/local/emhttp/plugins/diskviewer/include/diskviewer_api.php';

$cfg = @parse_plugin_cfg('diskviewer', true) ?: [];

// Theme detection. Mirror the widget convention: white + azure read as the
// light family, black + gray as dark. The tool uses a single dvt-light class
// (two-state) rather than the widget's four-theme tuning - the tool surfaces
// are simpler and don't need per-theme accent shifts.
$dynamix_cfg  = @parse_ini_file('/boot/config/plugins/dynamix/dynamix.cfg', true);
$unraid_theme = $dynamix_cfg['display']['theme'] ?? '';
$dvt_light    = in_array($unraid_theme, ['white', 'azure'], true);
$lightClass   = $dvt_light ? ' dvt-light' : '';

$tool_config = [
    'dvToken'    => DiskViewerEndpoint::generateNonce(),
    'csrfToken'  => (string)($var['csrf_token'] ?? ''),
    'lightTheme' => $dvt_light,
];
$tool_config_json = json_encode($tool_config, JSON_UNESCAPED_SLASHES);
?>

<link rel="stylesheet" type="text/css" href="/plugins/diskviewer/css/tool.css">
<script>window.diskviewerToolConfig = <?= $tool_config_json ?>;</script>

