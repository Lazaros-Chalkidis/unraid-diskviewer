<script>
/*
 * Page width unlocker. The dynamix template wraps standalone plugin pages in
 * a content container with a max-width around 1180px, leaving large gutters
 * on 2K/4K monitors. This walks up from .dvt-wrapper and removes any
 * max-width on ancestors narrower than the viewport. No-op when the wrapper
 * is absent. Same approach as the StreamViewer tool page.
 */
(function() {
    'use strict';
    function unlockAncestors() {
        var wrap = document.querySelector('.dvt-wrapper');
        if (!wrap) return;
        var vw = window.innerWidth || document.documentElement.clientWidth;
        var el = wrap.parentElement;
        while (el && el !== document.documentElement) {
            var cs = window.getComputedStyle(el);
            var mw = parseFloat(cs.maxWidth);
            if (!isNaN(mw) && mw > 0 && mw < vw) {
                el.style.setProperty('max-width', 'none', 'important');
            }
            el = el.parentElement;
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', unlockAncestors);
    } else {
        unlockAncestors();
    }
    window.addEventListener('resize', unlockAncestors);
})();
</script>
