require_once '/usr/local/emhttp/plugins/diskviewer/include/diskviewer_api.php';
require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';

$cfg = DiskViewerEndpoint::config();

$dynamix_cfg   = @parse_ini_file('/boot/config/plugins/dynamix/dynamix.cfg', true);
$unraid_theme  = $dynamix_cfg['display']['theme'] ?? '';
$valid_themes  = ['black','white','azure','gray'];
$dv_theme      = in_array($unraid_theme, $valid_themes, true) ? $unraid_theme : 'black';
$dv_light      = in_array($dv_theme, ['white','azure'], true);

$version_data        = @parse_ini_file('/etc/unraid-version');
$webgui_version      = $version_data['version'] ?? '0.0.0';
$isResponsiveWebgui  = version_compare($webgui_version, '7.2.0-beta', '>=');  // 7.2 reworked the dashboard tile header, so we render two layouts

$var = @parse_ini_file('/var/local/emhttp/var.ini') ?: [];
$csrf_token = (string)($var['csrf_token'] ?? '');

$initial_model = DiskViewerEndpoint::buildModel();

$tile_config = [
    'dvToken'             => DiskViewerEndpoint::generateNonce(),
    'csrfToken'           => $csrf_token,
    'refreshEnabled'      => $cfg['refresh_enabled'],
    'refreshInterval'     => $cfg['refresh_interval'] * 1000,
    'dragStepRows'        => $cfg['drag_step_rows'],
    'defaultExpandRows'   => $cfg['default_expand_rows'],
    'warningPct'          => $cfg['warning_pct'],
    'criticalPct'         => $cfg['critical_pct'],
    'spaceSeverityEnabled'=> $cfg['space_severity_enabled'],
    'tempWarning'         => $cfg['temp_warning'],
    'tempCritical'        => $cfg['temp_critical'],
    'tempUnit'            => $cfg['temp_unit'],
    'enableSpinButton'    => $cfg['enable_spin_button'],
    'poolHighlightUsed'   => $cfg['pool_highlight_used'],
    'showFsBadge'         => $cfg['show_fs_badge'],
    'showDiskErrors'      => $cfg['show_disk_errors'],
    'showDecimalPct'      => $cfg['show_decimal_pct'],
    'showUsedColumn'      => $cfg['show_used_column'],
    'showIdTooltip'       => $cfg['show_id_tooltip'],
    'showSectionIndicators' => $cfg['show_section_indicators'],
    'fontSize'            => $cfg['font_size'],
    'isResponsive'        => $isResponsiveWebgui,
    'initialModel'        => $initial_model,
];
$tile_config_json = json_encode($tile_config, JSON_UNESCAPED_SLASHES);

$tile_title = htmlspecialchars(_('Disk Viewer'), ENT_QUOTES, 'UTF-8');

$render_controls = static function(bool $responsive): string {
    $wrapOpen  = $responsive ? '<span class="tile-header-right-controls">' : '';
    $wrapClose = $responsive ? '</span>' : '';

    return $wrapOpen . <<<HTML
<a id="dv-manual-refresh" href="#" title="Refresh" aria-label="Refresh">
    <i class="fa fa-fw fa-refresh control" aria-hidden="true"></i>
</a>
<a id="dv-tool-icon" href="/Tools/DiskViewerTool" title="Open Disk Viewer page" aria-label="Open Disk Viewer page">
    <i class="fa fa-fw fa-hdd-o control" aria-hidden="true"></i>
</a>
<a id="dv-settings-icon" href="/Settings/DiskViewerSettings" title="Disk Viewer Settings" aria-label="Disk Viewer Settings">
    <i class="fa fa-fw fa-cog control" aria-hidden="true"></i>
</a>
HTML . $wrapClose;
};

$render_subtitle = static function(): string {
    return <<<HTML
<div class="dv-header-meta">
    <span class="dv-badge-devices" id="dv-badge-devices" title="Total devices">
        <span class="dv-badge-label">Total</span>
        <span id="dv-device-count">0</span>
        <span class="dv-badge-label">Devices</span>
        <span class="dv-badge-missing" id="dv-badge-missing" style="display:none;"></span>
    </span>
</div>
HTML;
};

$render_body = static function(): string {
    return <<<HTML
<div class="dv-body">
    <div id="dv-sections" class="dv-sections" role="list" aria-live="polite" aria-label="Disks">
        <div class="dv-empty-state" id="dv-empty-state">
            <span>Loading disks…</span>
        </div>
    </div>
    <div class="dv-drag-handle" id="dv-drag-handle" role="separator" aria-orientation="horizontal" aria-label="Resize disk list" tabindex="0" title="Drag to reveal more rows">
        <div class="dv-drag-grip">
            <div class="dv-drag-bar"></div>
            <div class="dv-drag-bar"></div>
        </div>
    </div>
</div>
HTML;
};

$render_config = static function(string $json): string {
    return <<<HTML
<script>
window.diskviewerConfig = {$json};
if (typeof window.diskviewerRepaint === 'function') {
    try { window.diskviewerRepaint(); } catch(e) {}
}
</script>
HTML;
};

$render_header_responsive = static function(
    string $tile_title,
    string $subtitle_html,
    string $controls_html
): string {
    return <<<HTML
<span class="tile-header dv-header">
    <span class="tile-header-left dv-header__left">
        <div class="dv-header__top">
            <img src="/plugins/diskviewer/img/diskviewer.png"
                 class="dv-header__icon" alt="Disk Viewer"
                 style="width:32px;height:32px;object-fit:contain;">
            <h3 class="tile-header-main dv-header__title">{$tile_title}</h3>
        </div>
        {$subtitle_html}
    </span>
    <span class="tile-header-right dv-header__right">
        <div class="dv-header__controls">{$controls_html}</div>
    </span>
</span>
HTML;
};

$render_header_legacy = static function(
    string $tile_title,
    string $subtitle_html,
    string $controls_html
): string {
    return <<<HTML
<div class="dv-legacy-header">
    <div class="dv-legacy-header__left">
        <div class="dv-legacy-header__top">
            <i class="fa fa-hdd-o f32 dv-legacy-icon" aria-hidden="true"></i>
            <span class="dv-legacy-title">{$tile_title}</span>
        </div>
        {$subtitle_html}
    </div>
    <span class="dv-legacy-controls">{$controls_html}</span>
</div>
HTML;
};

$render_fallback_tbody = static function(
    string $tile_title,
    string $header_html,
    string $body_html,
    string $config_html,
    string $lightClass
): string {
    return <<<HTML
<link rel="stylesheet" type="text/css" href="/plugins/diskviewer/css/widget.css">
<tbody id="db-diskviewer" title="{$tile_title}" class="{$lightClass}">
    <tr>
        <td class="next" colspan="3">
            {$header_html}
        </td>
    </tr>
    <tr class="dash_diskviewer_toggle dv-content">
        <td colspan="3">
            {$body_html}
        </td>
    </tr>
</tbody>
{$config_html}
<script defer src="/plugins/diskviewer/js/diskviewer.js"></script>
HTML;
};

$subtitle_html = $render_subtitle();
$body_html     = $render_body();
$config_html   = $render_config($tile_config_json);

$controls_responsive = $render_controls(true);
$controls_legacy     = $render_controls(false);

$header_responsive = $render_header_responsive($tile_title, $subtitle_html, $controls_responsive);
$header_legacy     = $render_header_legacy($tile_title, $subtitle_html, $controls_legacy);

$tile = [
    'name'    => 'diskviewer',
    'title'   => 'Disk Viewer',
    'icon'    => 'fa-hdd-o',
    'content' => '',
    'small'   => 1,
    'medium'  => 1,
    'large'   => 2,
    'script'  => '/plugins/diskviewer/js/diskviewer.js',
    'style'   => '/plugins/diskviewer/css/widget.css',
];

$themeClass  = ' dv-theme-' . $dv_theme;
$lightClass  = $dv_light ? ' dv-light' : '';
$rootClasses = $themeClass . $lightClass;

$tile['content'] = '<div class="dv-widget-wrap' . $rootClasses . '">'
    . ($isResponsiveWebgui
        ? ($header_responsive . $body_html . $config_html)
        : ($header_legacy     . $body_html . $config_html))
    . '</div>';

$fallback_markup = $render_fallback_tbody(
    $tile_title,
    $isResponsiveWebgui ? $header_responsive : $header_legacy,
    $body_html,
    $config_html,
    trim($rootClasses)
);

// 7.x registers tiles through this helper, older builds get the fallback markup below
if (function_exists('register_dashboard_tile')) {
    $result = @register_dashboard_tile($tile);

    if (is_string($result) && trim($result) !== '') {
        echo $result;
        return;
    }

    if ($result) return;
}

$mytiles['diskviewer']['column1'] = $fallback_markup;
return;
?>
