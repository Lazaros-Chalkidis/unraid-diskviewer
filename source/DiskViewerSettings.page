          <span class="dv-credits-title">Disk Viewer</span>
          <span class="dv-credits-version">v<?php
            $_dvPluginVer = '';

            // Primary: VERSION file at the canonical installed location.
            // Hardcoded absolute path because __DIR__ in a .page file under
            // emhttp does not always resolve where one expects.
            $_dvVersionFile = '/usr/local/emhttp/plugins/diskviewer/VERSION';
            if (is_readable($_dvVersionFile)) {
                $_dvRead = trim((string)@file_get_contents($_dvVersionFile));
                if ($_dvRead !== '') {
                    $_dvPluginVer = $_dvRead;
                }
            }

            // Fallback: Slackware package metadata for legacy installs that
            // predate the VERSION file. Sort descending so the newest install
            // wins even if a stale entry was left behind.
            if ($_dvPluginVer === '') {
                $_dvPkgs = @glob('/var/log/packages/diskviewer-*');
                if (is_array($_dvPkgs) && !empty($_dvPkgs)) {
                    usort($_dvPkgs, function($a, $b) {
                        return @filemtime($b) - @filemtime($a);
                    });
                    $_dvBase = basename($_dvPkgs[0]);
                    if (preg_match('/^diskviewer-([^-]+(?:-[^-]+)?)/', $_dvBase, $_dvM)) {
                        $_dvPluginVer = $_dvM[1];
                    }
                }
            }

            echo htmlspecialchars($_dvPluginVer ?: '');
          ?></span>
