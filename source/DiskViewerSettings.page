// form sanitizers, every posted value gets clamped through one of these
$yn = static fn($v, $d = '0') => ((string)($v ?? $d) === '1') ? '1' : '0';

$clamp_int = static function($v, int $min, int $max, int $default): string {
    $n = is_numeric($v) ? (int)$v : $default;
    if ($n < $min) $n = $min;
    if ($n > $max) $n = $max;
    return (string)$n;
};

$clamp_interval = static function($v): string {
    $allowed = ['5','10','20','30','50','80','100'];
    return in_array((string)$v, $allowed, true) ? (string)$v : '20';
};

$clean_ids = static function($v): string {
    $ids = [];
    foreach (preg_split('/\s+/', trim((string)$v)) as $tok) {
        if ($tok !== '' && preg_match('~^[A-Za-z0-9._:\-]+$~', $tok)) $ids[$tok] = true;
    }
    return implode(' ', array_keys($ids));
};

