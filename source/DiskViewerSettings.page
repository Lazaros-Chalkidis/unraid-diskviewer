<script>
(function(){
    'use strict';

    // ── Settings tabs (Widget / Tool) ──────────────────────────────────
    (function(){
        var TAB_MAP = { dvTabWidget: 'dvWidgetTabPanel', dvTabTool: 'dvToolTabPanel' };
        var hidden  = document.getElementById('dvActiveTab');
        function activate(tabId){
            var key = tabId === 'dvTabTool' ? 'tool' : 'widget';
            Object.keys(TAB_MAP).forEach(function(tid){
                var tab = document.getElementById(tid);
                var panel = document.getElementById(TAB_MAP[tid]);
                if (tab)   tab.classList.toggle('active', tid === tabId);
                if (panel) panel.style.display = (tid === tabId) ? '' : 'none';
            });
            if (hidden) hidden.value = key;
        }
        Object.keys(TAB_MAP).forEach(function(tid){
            var tab = document.getElementById(tid);
            if (!tab) return;
            tab.addEventListener('click', function(){ activate(tid); });
            tab.addEventListener('keydown', function(e){
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(tid); }
            });
        });
    })();

    // ── Section collapse/expand ─────────────────────────────────────────
    document.querySelectorAll('.dv-sec-hd').forEach(function(hd){
        hd.addEventListener('click', function(){
            hd.parentElement.classList.toggle('closed');
        });
    });

    // ── Toggle hidden-input sync (mirrors StreamViewer) ─────────────────
    // The visible <input type="checkbox"> in .dv-toggle is a UI proxy; the
    // actual form value lives in a sibling <input type="hidden">. Keeping
    // them in sync on every change avoids a stale POST when the form is
    // submitted via AJAX (which serializes hidden inputs, not unchecked
    // checkboxes).
    document.querySelectorAll('input[data-dv-toggle]').forEach(function(cb){
        cb.addEventListener('change', function(){
            var name = cb.getAttribute('data-dv-toggle');
            var hidden = document.querySelector('input[type="hidden"][name="' + name + '"]');
            if (hidden) hidden.value = cb.checked ? '1' : '0';
            var txt = cb.closest('.dv-r-field').querySelector('.dv-toggle-txt');
            if (txt) {
                var isShow = txt.textContent.trim() === 'Show' || txt.textContent.trim() === 'Hide';
                txt.textContent = cb.checked ? (isShow ? 'Show' : 'Enabled') : (isShow ? 'Hide' : 'Disabled');
                txt.classList.toggle('on',  cb.checked);
                txt.classList.toggle('off', !cb.checked);
            }
        });
    });

    // ── Native form submit ──────────────────────────────────────────────
    // Apply button is <button type="submit" name="#apply"> which triggers
    // a normal browser POST when clicked. No JS interception of the
    // submission itself - the browser sends the form, the server writes
    // the cfg file, and the response is the same page re-rendered with
    // the new values. This is the same pattern Logs Viewer and Stream
    // Viewer use, and it side-steps every race condition the previous
    // AJAX flow had (CSRF token rotation, browser cache of POST
    // responses, dashboard-tile DOM swap).
    //
    // What we DO add back is a spinner animation: while the POST is in
    // flight (and the page reload is in flight), swap the Apply button's
    // icon and label to a spinning gear so the user gets feedback that
    // the click registered. The browser navigates to the new page as
    // normal; when the response arrives the freshly-rendered Apply button
    // replaces the spinner version. We also disable the button so a
    // double-click can't fire a second submit. This listens on `submit`
    // (not `click`) so keyboard Enter on a focused field also triggers
    // the spinner.
    var form     = document.querySelector('form[name="diskviewer_settings"]');
    var applyBtn = document.getElementById('dvApplyBtn');
    if (form && applyBtn) {
        form.addEventListener('submit', function(){
            // Defer the visual swap to a 0ms setTimeout so it runs AFTER
            // the browser has serialised the form (including the Apply
            // button's name="#apply" value="apply" pair which triggers
            // the PHP POST handler). Disabling or re-rendering the button
            // synchronously inside the submit handler would strip it from
            // the form payload because disabled / replaced controls don't
            // submit, and the server would then fall through to the GET
            // branch and reload defaults. The 0ms timer puts the swap on
            // the next tick of the event loop, by which time the browser
            // has captured the form and dispatched the POST.
            setTimeout(function(){
                applyBtn.disabled  = true;
                applyBtn.innerHTML = '<i class="fa fa-spinner fa-spin" aria-hidden="true"></i> Saving\u2026';
            }, 0);
        });
    }

    // ── Reset to defaults ───────────────────────────────────────────────
    // Walks every form field and reapplies its baked-in default value, then
    // syncs the visible toggle thumbs and labels to match. This is a UI
    // reset only - nothing is persisted until the user clicks Apply, which
    // matches the behaviour the user expects from "Reset" in similar
    // Unraid settings pages.
    var DV_DEFAULTS = {
        REFRESH_ENABLED:      '1',
        REFRESH_INTERVAL:     '20',
        DRAG_STEP_ROWS:       '1',
        ENABLE_SPIN_BUTTON:   '1',
        SHOW_ARRAY:           '1',
        SHOW_CACHE:           '1',
        SHOW_POOLS:           '1',
        SHOW_UNASSIGNED:      '0',
        HEADER_SHOW_BADGE:    '1',
        HEADER_CLICK_ACTION:  'main',
        POOL_HIGHLIGHT_USED:  '0',
        SHOW_FS_BADGE:        '1',
        SHOW_DISK_ERRORS:     '1',
        SHOW_DECIMAL_PCT:     '1',
        SHOW_USED_COLUMN:     '1',
        SHOW_SECTION_INDICATORS: '1',
        FONT_SIZE:            'default',
        SPACE_SEVERITY_MODE:  'inherit',
        SPACE_WARNING_PCT:    '70',
        SPACE_CRITICAL_PCT:   '90',
        TOOL_REFRESH_ENABLED:      '1',
        TOOL_REFRESH_INTERVAL:     '10',
        TOOL_ENABLE_SPIN_BUTTON:   '1',
        TOOL_SHOW_ARRAY:           '1',
        TOOL_SHOW_CACHE:           '1',
        TOOL_SHOW_POOLS:           '1',
        TOOL_SHOW_UNASSIGNED:      '0',
        TOOL_HEADER_SHOW_BADGE:    '1',
        TOOL_HEADER_CLICK_ACTION:  'main',
        TOOL_SHOW_DECIMAL_PCT:     '1',
        TOOL_SHOW_USED_COLUMN:     '1',
        TOOL_FONT_SIZE:            'default',
        TOOL_SPACE_SEVERITY_MODE:  'inherit',
        TOOL_SPACE_WARNING_PCT:    '70',
        TOOL_SPACE_CRITICAL_PCT:   '90'
    };

    function resetDefaults(){
        if (!form) return;
        // Per-tab reset: only restore the keys that belong to the tab the user
        // is currently on. Tool keys are TOOL_-prefixed; everything else is a
        // widget key. DV_ACTIVE_TAB is global and never reset.
        var activeTab = (document.getElementById('dvActiveTab') || {}).value || 'widget';
        var isTool = (activeTab === 'tool');
        function inActiveTab(key){
            if (key === 'DV_ACTIVE_TAB') return false;
            var keyIsTool = key.indexOf('TOOL_') === 0;
            return isTool ? keyIsTool : !keyIsTool;
        }
        Object.keys(DV_DEFAULTS).forEach(function(k){
            if (!inActiveTab(k)) return;
            var el = form.querySelector('[name="' + k + '"]');
            if (el) el.value = DV_DEFAULTS[k];
        });
        // Sync each visible toggle thumb to its hidden value (active tab only)
        document.querySelectorAll('.dv-toggle input[type="checkbox"]').forEach(function(cb){
            var name = cb.getAttribute('data-dv-toggle');
            if (!name || !DV_DEFAULTS.hasOwnProperty(name)) return;
            if (!inActiveTab(name)) return;
            cb.checked = DV_DEFAULTS[name] === '1';
            var txt = cb.closest('.dv-r-field').querySelector('.dv-toggle-txt');
            if (txt) {
                var isShow = txt.textContent.trim() === 'Show' || txt.textContent.trim() === 'Hide';
                txt.textContent = cb.checked ? (isShow ? 'Show' : 'Enabled') : (isShow ? 'Hide' : 'Disabled');
                txt.className = 'dv-toggle-txt ' + (cb.checked ? 'on' : 'off');
            }
        });
        // Re-evaluate the show/hide visibility for the custom-only rows
        // (warning/critical inputs) after the mode dropdown was reset.
        if (typeof dvUpdateSpaceSeverityRows === 'function') {
            dvUpdateSpaceSeverityRows();
        }
        if (typeof dvtUpdateSpaceSeverityRows === 'function') {
            dvtUpdateSpaceSeverityRows();
        }
        dvShowNotice(
            (isTool ? 'Tool settings reset' : 'Widget settings reset'),
            'The ' + (isTool ? 'Tool' : 'Widget') + ' settings have been restored to their '
              + 'default values. Click '
              + '<span style="color:#f47d42;font-weight:600;">Apply</span> to save.'
        );
    }

    var resetBtn = document.getElementById('dvResetBtn');
    if (resetBtn) resetBtn.addEventListener('click', resetDefaults);

    // ── Space severity mode show/hide ─────────────────────────────────────
    // The "Custom warning percentage" and "Custom critical percentage" rows
    // are only meaningful when the user has picked the 'custom' mode in the
    // Space severity highlighting dropdown. In the other two modes (inherit,
    // disabled) the inputs are visually grey-disabled rather than removed
    // from the DOM, so the user still sees what values would apply if they
    // switched to custom - and so the form submit always carries them, in
    // case the user toggles back without re-typing.
    var dvSpaceModeSel = document.getElementById('dvSpaceSeverityMode');
    var dvSpaceWarnIn  = document.getElementById('dvSpaceWarn');
    var dvSpaceCritIn  = document.getElementById('dvSpaceCrit');
    function dvUpdateSpaceSeverityRows(){
        if (!dvSpaceModeSel) return;
        var active = (dvSpaceModeSel.value === 'custom');
        [dvSpaceWarnIn, dvSpaceCritIn].forEach(function(el){
            if (!el) return;
            el.disabled = !active;
            // Lift opacity on the whole row so the explanatory descriptions
            // also dim when the inputs are inactive. The row carries
            // data-dv-show-when="custom" so other CSS could target it too.
            var row = el.closest('.dv-r');
            if (row) row.style.opacity = active ? '' : '0.5';
        });
    }
    if (dvSpaceModeSel) {
        dvSpaceModeSel.addEventListener('change', dvUpdateSpaceSeverityRows);
        dvUpdateSpaceSeverityRows();
    }
    // Expose for resetDefaults() to call after it updates the dropdown.
    window.dvUpdateSpaceSeverityRows = dvUpdateSpaceSeverityRows;

    // ── Tool tab: space severity custom rows (independent handler) ──────
    var dvtSpaceModeSel = document.getElementById('dvtSpaceSeverityMode');
    var dvtSpaceWarnIn  = document.getElementById('dvtSpaceWarn');
    var dvtSpaceCritIn  = document.getElementById('dvtSpaceCrit');
    function dvtUpdateSpaceSeverityRows(){
        if (!dvtSpaceModeSel) return;
        var active = (dvtSpaceModeSel.value === 'custom');
        [dvtSpaceWarnIn, dvtSpaceCritIn].forEach(function(el){
            if (!el) return;
            el.disabled = !active;
            var row = el.closest('.dv-r');
            if (row) row.style.opacity = active ? '' : '0.5';
        });
    }
    if (dvtSpaceModeSel) {
        dvtSpaceModeSel.addEventListener('change', dvtUpdateSpaceSeverityRows);
        dvtUpdateSpaceSeverityRows();
    }
    window.dvtUpdateSpaceSeverityRows = dvtUpdateSpaceSeverityRows;

    // ── Notice modal (replaces window.alert for plugin-side notifications) ─
    // dvShowNotice(title, body) opens the notice modal with the given title
    // and body text. Closes on OK button, backdrop click, or Escape - same
    // affordances as the credits modal so the user behaviour is consistent.
    // Falls back to a plain alert() if for some reason the modal node is
    // missing (template stripped, theme override hid it, etc.).
    function dvShowNotice(title, bodyHtml){
        var nModal = document.getElementById('dvNoticeModal');
        var nTitle = document.getElementById('dvNoticeTitle');
        var nBody  = document.getElementById('dvNoticeBody');
        if (!nModal || !nTitle || !nBody) {
            // Strip HTML for the alert fallback so the user sees clean text
            // instead of raw markup if the modal node went missing.
            var plain = (bodyHtml || '').replace(/<[^>]+>/g, '');
            alert(title + (plain ? '\n\n' + plain : ''));
            return;
        }
        // Title is plain text; body accepts a small set of HTML for
        // typographic emphasis (e.g. <span style="color:#f47d42">Apply</span>).
        // The body string is fully controlled by the plugin's own JS - it
        // never carries user input - so HTML insertion is safe here.
        nTitle.textContent = title || 'Notice';
        nBody.innerHTML    = bodyHtml || '';
        nModal.style.display = 'flex';
    }
    var nModal = document.getElementById('dvNoticeModal');
    var nOk    = document.getElementById('dvNoticeOkBtn');
    if (nOk && nModal) nOk.addEventListener('click', function(){
        nModal.style.display = 'none';
    });
    if (nModal) {
        nModal.addEventListener('click', function(e){
            if (e.target === nModal) nModal.style.display = 'none';
        });
        document.addEventListener('keydown', function(e){
            if (e.key === 'Escape' && nModal.style.display !== 'none') {
                nModal.style.display = 'none';
            }
        });
    }

    // ── Credits modal ───────────────────────────────────────────────────
    // Open on link click, close on OK button, backdrop click, or Escape.
    var modal = document.getElementById('dvCreditsModal');
    var cLink = document.getElementById('dvCreditsLink');
    var okBtn = document.getElementById('dvCreditsOkBtn');
    if (cLink && modal) cLink.addEventListener('click', function(e){
        e.preventDefault();
        modal.style.display = 'flex';
    });
    if (okBtn && modal) okBtn.addEventListener('click', function(){
        modal.style.display = 'none';
    });
    if (modal) {
        modal.addEventListener('click', function(e){
            if (e.target === modal) modal.style.display = 'none';
        });
        document.addEventListener('keydown', function(e){
            if (e.key === 'Escape') modal.style.display = 'none';
        });
    }
})();
</script>
