require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';
require_once '/usr/local/emhttp/plugins/diskviewer/include/diskviewer_api.php';

const DV_PLUGIN   = 'diskviewer';
const DV_CFG_FILE = '/boot/config/plugins/diskviewer/diskviewer.cfg';


// ============================================================================
// 1. Server-side: sanitizers, POST handler, defaults, theme, version
// ============================================================================

// ── Sanitizers ─────────────────────────────────────────────────────────────
$yn = static fn($v, $d = '0') => ((string)($v ?? $d) === '1') ? '1' : '0';

$clamp_int = static function($v, int $min, int $max, int $default): string {
    $n = is_numeric($v) ? (int)$v : $default;
    if ($n < $min) $n = $min;
    if ($n > $max) $n = $max;
    return (string)$n;
};

$clamp_interval = static function($v): string {
    $allowed = ['5','10','20','30','50','80','100'];
    return in_array((string)$v, $allowed, true) ? (string)$v : '20';
};

// ── POST handler ───────────────────────────────────────────────────────────
// Simple browser POST submission, matching the pattern Logs Viewer (and
// Stream Viewer) use. The form submits natively (no AJAX, no
// preventDefault), this block writes the cfg file, and execution falls
// through to the rest of the page which re-reads the cfg and renders
// every field at its persisted value. The browser sees a normal 200 OK
// and displays the response.
//
// Why no CSRF: emhttpd's session auth gates the WebGUI in front of
// every plugin page, and /boot/config is root-write-only at the
// filesystem level. Other Unraid plugins (Logs Viewer, Stream Viewer,
// the official dynamix.* settings pages) follow the same convention -
// adding a CSRF check here was breaking Apply with no actual
// security improvement to show for it, since cross-origin POSTs are
// already blocked by emhttpd's session cookie + same-site policy.
//
// Why no AJAX: the previous AJAX flow tried to keep the user on the
// page and reload via JS, but ran into race conditions with CSRF
// rotation, browser caching of POST responses, and the dashboard
// auto-refresh DOM swap. A plain submit Just Works.
if (isset($_POST['#apply'])) {
    // Per-tab apply: load the settings already on disk and overlay only the
    // keys of the tab that was actually submitted, so applying the Widget tab
    // never overwrites Tool settings and vice versa. DV_ACTIVE_TAB is global.
    $new_cfg = @parse_ini_file(DV_CFG_FILE) ?: [];

    $tabIn = (string)($_POST['dv_active_tab'] ?? 'widget');
    $tabIn = in_array($tabIn, ['widget','tool'], true) ? $tabIn : 'widget';
    $new_cfg['DV_ACTIVE_TAB'] = $tabIn;

    if ($tabIn === 'widget') {
    // Behavior
    $new_cfg['REFRESH_ENABLED']   = $yn($_POST['REFRESH_ENABLED']  ?? '1', '1');
    $new_cfg['REFRESH_INTERVAL']  = $clamp_interval($_POST['REFRESH_INTERVAL'] ?? 20);
    $new_cfg['DRAG_STEP_ROWS']    = $clamp_int($_POST['DRAG_STEP_ROWS'] ?? 1, 1, 5, 1);
    // Allow spin actions (moved here from the removed Spin control section).
    // The backend guard inside diskviewer_api.php still blocks parity and
    // multi-disk pool members regardless of this toggle.
    $new_cfg['ENABLE_SPIN_BUTTON']   = $yn($_POST['ENABLE_SPIN_BUTTON'] ?? '1', '1');

    // Display
    $new_cfg['SHOW_UNASSIGNED']      = $yn($_POST['SHOW_UNASSIGNED']      ?? '0', '0');
    $new_cfg['SHOW_ARRAY']           = $yn($_POST['SHOW_ARRAY']           ?? '1', '1');
    $new_cfg['SHOW_CACHE']           = $yn($_POST['SHOW_CACHE']           ?? '1', '1');
    $new_cfg['SHOW_POOLS']           = $yn($_POST['SHOW_POOLS']           ?? '1', '1');
    // Header bar indicator toggle - moved here from its own section, kept
    // as a Display option since it controls whether the Unraid header
    // badge is rendered.
    $new_cfg['HEADER_SHOW_BADGE']    = $yn($_POST['HEADER_SHOW_BADGE'] ?? '1', '1');
    // Header click action - which Unraid page opens when the user
    // clicks the indicator. Whitelisted to main / widget / settings;
    // anything else falls back to 'main'. The JS polls the click
    // action from the server every 30s, so changing this setting
    // takes effect on the next poll without a page refresh.
    $clickActionIn = (string)($_POST['HEADER_CLICK_ACTION'] ?? 'main');
    $new_cfg['HEADER_CLICK_ACTION']  = in_array($clickActionIn, ['main','widget','tool','settings'], true)
        ? $clickActionIn : 'main';
    // Pool severity highlight - when on, single-disk pool tiles whose
    // used % crosses warning/critical threshold paint amber/red over
    // the zebra background. Default off so the zebra reads as a clean
    // table on fresh installs.
    $new_cfg['POOL_HIGHLIGHT_USED']  = $yn($_POST['POOL_HIGHLIGHT_USED'] ?? '0', '1');
    // FS badge on aggregate rows.
    $new_cfg['SHOW_FS_BADGE']        = $yn($_POST['SHOW_FS_BADGE'] ?? '1', '1');
    // Disk error indicator master switch (warning triangle in section
    // headers + disk-silhouette tint on the Unraid header indicator).
    // Default on - error detection is one of the most useful signals
    // the widget provides, so it should be visible unless the user
    // explicitly turns it off.
    $new_cfg['SHOW_DISK_ERRORS']     = $yn($_POST['SHOW_DISK_ERRORS'] ?? '1', '1');
    // Decimal precision on the USED % column. Default off - integer
    // percent ("65%") stays the baseline; enabling it shows one decimal
    // ("65.4%") which is useful on multi-TB drives where 1% can hide
    // over 100 GB of capacity.
    $new_cfg['SHOW_DECIMAL_PCT']     = $yn($_POST['SHOW_DECIMAL_PCT'] ?? '1', '1');
    // USED bytes column. Default off so the upgrade doesn't disrupt
    // the layout existing users are used to. When on, an extra column
    // is inserted between SIZE and FREE showing the absolute used
    // bytes (matches Unraid Main page column order).
    $new_cfg['SHOW_USED_COLUMN']     = $yn($_POST['SHOW_USED_COLUMN'] ?? '1', '1');
    // Section-header indicators (errors / high-temp / bad-health icons
    // with disk counts next to ARRAY/CACHE/RAID/POOL labels). Default on.
    $new_cfg['SHOW_SECTION_INDICATORS'] = $yn($_POST['SHOW_SECTION_INDICATORS'] ?? '1', '1');
    // Widget font size for disk-info rows. Whitelisted; anything unknown
    // falls back to default.
    $new_cfg['FONT_SIZE']            = in_array($_POST['FONT_SIZE'] ?? 'default', ['small','default','large'], true) ? $_POST['FONT_SIZE'] : 'default';

    // Space severity. Mode is a 3-option whitelist; the two custom percent
    // values are clamped to a sane band. Note: critical-must-exceed-warning
    // is enforced on the read side (DiskViewerEndpoint::config) too, so a
    // user typing identical values won't break colour coding - the resolver
    // bumps critical to warning+1 silently.
    $mode_in = strtolower((string)($_POST['SPACE_SEVERITY_MODE'] ?? 'inherit'));
    $new_cfg['SPACE_SEVERITY_MODE'] = in_array($mode_in, ['inherit','custom','disabled'], true)
        ? $mode_in : 'inherit';
    $new_cfg['SPACE_WARNING_PCT']   = $clamp_int($_POST['SPACE_WARNING_PCT']  ?? 70,  1,  99,  70);
    $new_cfg['SPACE_CRITICAL_PCT']  = $clamp_int($_POST['SPACE_CRITICAL_PCT'] ?? 90,  2, 100,  90);

    } else {
    // ── TOOL PAGE SETTINGS (independent of the widget) ──────────────────
    // Same options as the widget, configured separately for the standalone
    // Disk Viewer page. Same clamps/whitelists. DRAG_STEP_ROWS is not
    // mirrored - the tool shows every row, there is no drag-to-expand.
    $new_cfg['TOOL_REFRESH_ENABLED']     = $yn($_POST['TOOL_REFRESH_ENABLED'] ?? '1', '1');
    $new_cfg['TOOL_REFRESH_INTERVAL']    = $clamp_interval($_POST['TOOL_REFRESH_INTERVAL'] ?? 10);
    $new_cfg['TOOL_ENABLE_SPIN_BUTTON']  = $yn($_POST['TOOL_ENABLE_SPIN_BUTTON'] ?? '1', '1');
    $new_cfg['TOOL_SHOW_UNASSIGNED']     = $yn($_POST['TOOL_SHOW_UNASSIGNED'] ?? '0', '0');
    $new_cfg['TOOL_SHOW_ARRAY']          = $yn($_POST['TOOL_SHOW_ARRAY'] ?? '1', '1');
    $new_cfg['TOOL_SHOW_CACHE']          = $yn($_POST['TOOL_SHOW_CACHE'] ?? '1', '1');
    $new_cfg['TOOL_SHOW_POOLS']          = $yn($_POST['TOOL_SHOW_POOLS'] ?? '1', '1');
    // Header indicator settings: shown dimmed in the Tool tab, only meaningful
    // as a fallback when the dashboard widget is not active. Persisted either
    // way so the value is ready if the tool ever takes over the indicator.
    $new_cfg['TOOL_HEADER_SHOW_BADGE']   = $yn($_POST['TOOL_HEADER_SHOW_BADGE'] ?? '1', '1');
    $toolClickIn = (string)($_POST['TOOL_HEADER_CLICK_ACTION'] ?? 'main');
    $new_cfg['TOOL_HEADER_CLICK_ACTION'] = in_array($toolClickIn, ['main','widget','tool','settings'], true) ? $toolClickIn : 'main';
    $new_cfg['TOOL_SHOW_DECIMAL_PCT']    = $yn($_POST['TOOL_SHOW_DECIMAL_PCT'] ?? '1', '1');
    $new_cfg['TOOL_SHOW_USED_COLUMN']    = $yn($_POST['TOOL_SHOW_USED_COLUMN'] ?? '1', '1');
    $new_cfg['TOOL_FONT_SIZE']           = in_array($_POST['TOOL_FONT_SIZE'] ?? 'default', ['small','default','large'], true) ? $_POST['TOOL_FONT_SIZE'] : 'default';
    $toolModeIn = strtolower((string)($_POST['TOOL_SPACE_SEVERITY_MODE'] ?? 'inherit'));
    $new_cfg['TOOL_SPACE_SEVERITY_MODE'] = in_array($toolModeIn, ['inherit','custom','disabled'], true) ? $toolModeIn : 'inherit';
    $new_cfg['TOOL_SPACE_WARNING_PCT']   = $clamp_int($_POST['TOOL_SPACE_WARNING_PCT']  ?? 70, 1,  99,  70);
    $new_cfg['TOOL_SPACE_CRITICAL_PCT']  = $clamp_int($_POST['TOOL_SPACE_CRITICAL_PCT'] ?? 90, 2, 100,  90);
    }

    // Serialize. Each value goes through its own clamp/whitelist above, so
    // it cannot contain newlines or quotes by the time it reaches this
    // loop - but defense in depth: strip control chars and escape any
    // embedded double quotes.
    $ini = '';
    foreach ($new_cfg as $k => $v) {
        $v = preg_replace('/[\x00-\x1f\x7f]/', '', (string)$v);
        $v = str_replace('"', '\\"', $v);
        $ini .= "{$k}=\"{$v}\"\n";
    }
    @mkdir(dirname(DV_CFG_FILE), 0755, true);
    file_put_contents(DV_CFG_FILE, $ini);

    $cfg = $new_cfg;
} else {
    $cfg = @parse_ini_file(DV_CFG_FILE) ?: [];
}

// Defaults
$def = [
    'REFRESH_ENABLED'      => '1',
    'DV_ACTIVE_TAB'        => 'widget',
    'REFRESH_INTERVAL'     => '20',
    'DRAG_STEP_ROWS'       => '1',
    'ENABLE_SPIN_BUTTON'   => '1',
    'SHOW_UNASSIGNED'      => '0',
    'SHOW_ARRAY'           => '1',
    'SHOW_CACHE'           => '1',
    'SHOW_POOLS'           => '1',
    'HEADER_SHOW_BADGE'    => '1',
    'HEADER_CLICK_ACTION'  => 'main',
    'POOL_HIGHLIGHT_USED'  => '0',
    'SHOW_FS_BADGE'        => '1',
    'SHOW_DISK_ERRORS'     => '1',
    'SHOW_DECIMAL_PCT'     => '1',
    'SHOW_USED_COLUMN'     => '1',
    'SHOW_SECTION_INDICATORS' => '1',
    'FONT_SIZE'            => 'default',
    'SPACE_SEVERITY_MODE'  => 'inherit',
    'SPACE_WARNING_PCT'    => '70',
    'SPACE_CRITICAL_PCT'   => '90',
    // Tool page settings (independent of widget)
    'TOOL_REFRESH_ENABLED'      => '1',
    'TOOL_REFRESH_INTERVAL'     => '10',
    'TOOL_ENABLE_SPIN_BUTTON'   => '1',
    'TOOL_SHOW_UNASSIGNED'      => '0',
    'TOOL_SHOW_ARRAY'           => '1',
    'TOOL_SHOW_CACHE'           => '1',
    'TOOL_SHOW_POOLS'           => '1',
    'TOOL_HEADER_SHOW_BADGE'    => '1',
    'TOOL_HEADER_CLICK_ACTION'  => 'main',
    'TOOL_SHOW_DECIMAL_PCT'     => '1',
    'TOOL_SHOW_USED_COLUMN'     => '1',
    'TOOL_FONT_SIZE'            => 'default',
    'TOOL_SPACE_SEVERITY_MODE'  => 'inherit',
    'TOOL_SPACE_WARNING_PCT'    => '70',
    'TOOL_SPACE_CRITICAL_PCT'   => '90',
];
foreach ($def as $k => $v) {
    if (!isset($cfg[$k]) || $cfg[$k] === '') $cfg[$k] = $v;
}

// Active settings tab (Widget / Tool).
$active_tab = (string)($cfg['DV_ACTIVE_TAB'] ?? 'widget');
if (!in_array($active_tab, ['widget','tool'], true)) $active_tab = 'widget';

// Whether the dashboard widget is in active use. When it is not, the Tool
// tab's header-indicator options unlock (the tool becomes the fallback
// owner of the Unraid header indicator).
$widget_active = DiskViewerEndpoint::widgetActive();
$headerBlockCls = 'dv-dimmed-block' . ($widget_active ? '' : ' dv-unlocked');

// Theme detection. See DiskViewer.page for the full rationale - same
// black/white/azure/gray scheme, same dv-theme-{name} class, plus dv-light
// retained as an alias for white/azure so the legacy two-state CSS that
// already exists in settings.css continues to apply without rewriting.
$dynamix_cfg   = @parse_ini_file('/boot/config/plugins/dynamix/dynamix.cfg', true);
$unraid_theme  = $dynamix_cfg['display']['theme'] ?? '';
$valid_themes  = ['black','white','azure','gray'];
$dv_theme      = in_array($unraid_theme, $valid_themes, true) ? $unraid_theme : 'black';
$dv_light      = in_array($dv_theme, ['white','azure'], true);
$themeClass    = ' dv-theme-' . $dv_theme;
$lightClass    = $dv_light ? ' dv-light' : '';
$rootClasses   = $themeClass . $lightClass;

// Plugin version - mirrors StreamViewer's dual-source pattern. Primary
// is the VERSION file at the canonical installed location (written by
// build.sh on every build), so the badge always reflects the running
// plugin even when the .plg metadata went stale (manual installs, edits
// during testing). Fallback to the .plg ENTITY for legacy installs that
// predate the VERSION file. Final fallback: literal 'dev' so the badge
// never appears empty - useful while developing out of the source tree.
$plugin_version = '';
$_pvFile = '/usr/local/emhttp/plugins/diskviewer/VERSION';
if (is_readable($_pvFile)) {
    $_pvRead = trim((string)@file_get_contents($_pvFile));
    if ($_pvRead !== '') $plugin_version = $_pvRead;
}
if ($plugin_version === '') {
    $plg = @file_get_contents('/boot/config/plugins/diskviewer/diskviewer.plg');
    if ($plg && preg_match('/<!ENTITY\s+version\s+"([^"]+)"/i', $plg, $m)) {
        $plugin_version = $m[1];
    }
}
if ($plugin_version === '') $plugin_version = 'dev';
?>

