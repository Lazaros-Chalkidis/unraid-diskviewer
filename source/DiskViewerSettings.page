$toggle = function($name, $val, $default = '1', $onLabel = 'Enabled', $offLabel = 'Disabled') {
    $isOn = ((string)($val ?? $default)) === '1';
    $checked = $isOn ? ' checked' : '';
    $txtClass = $isOn ? 'on' : 'off';
    $txtLabel = $isOn ? $onLabel : $offLabel;
    return '<input type="hidden" name="' . $name . '" value="' . ($isOn ? '1' : '0') . '">'
        . '<label class="dv-toggle"><input type="checkbox" data-dv-toggle="' . $name . '"' . $checked . '>'
        . '<span class="dv-toggle-track"></span></label>'
        . '<span class="dv-toggle-txt ' . $txtClass . '">' . $txtLabel . '</span>';
};
$toggleShow = function($name, $val, $default = '1') use ($toggle) {
    return $toggle($name, $val, $default, 'Show', 'Hide');
};

$dvHideable = DiskViewerEndpoint::hideableDevices();
$dvRenderVis = function(string $field, $hiddenRaw) use ($dvHideable) {
    $hiddenSet = [];
    foreach (preg_split('/\s+/', trim((string)$hiddenRaw)) as $id) { if ($id !== '') $hiddenSet[$id] = true; }
    $present = 0;
    $groups = ['unassigned' => [], 'pool' => []];
    foreach ($dvHideable as $d) {
        if (isset($hiddenSet[$d['byid']])) $present++;
        $groups[$d['cat']][] = $d;
    }
    $cell = function($d) use ($hiddenSet) {
        $isHidden = isset($hiddenSet[$d['byid']]);
        $h  = '<label class="dv-vis-cell' . ($isHidden ? ' is-hidden' : '') . '">';
        $h .= '<span class="dv-vis-cell-main">';
        $h .= '<span class="dv-vis-nameline"><span class="dv-vis-name">' . htmlspecialchars($d['name']) . '</span><span class="dv-vis-size">' . htmlspecialchars($d['size_h']) . '</span></span>';
        $h .= '<span class="dv-vis-id">' . htmlspecialchars($d['byid']) . '</span>';
        $h .= '</span>';
        $h .= '<input type="checkbox" class="dv-vis-tg" data-byid="' . htmlspecialchars($d['byid'], ENT_QUOTES) . '"' . ($isHidden ? '' : ' checked') . '>';
        $h .= '<span class="dv-vis-track"></span></label>';
        return $h;
    };
    ob_start();
    ?>
      <div class="dv-vis-block" data-field="<?= htmlspecialchars($field, ENT_QUOTES) ?>">
        <div class="dv-vis-bar">
          <span class="dv-vis-count"><i class="fa fa-eye-slash" aria-hidden="true"></i> <span class="dv-vis-count-n"><?= $present ?></span> hidden</span>
          <button type="button" class="dv-vis-rescan dv-action-btn dv-action-btn--reset"><i class="fa fa-refresh" aria-hidden="true"></i> Rescan</button>
        </div>
        <div class="dv-vis-list">
          <?php if (empty($dvHideable)): ?>
            <div class="dv-vis-empty">No unassigned devices or single-disk pools were found.</div>
          <?php else: foreach ($groups as $cat => $list): if (empty($list)) continue; ?>
            <div class="dv-vis-group"><?= $cat === 'unassigned' ? 'Unassigned' : 'Single-disk pools' ?></div>
            <div class="dv-vis-rows">
              <?php foreach (array_chunk($list, 3) as $rowCells): ?>
                <div class="dv-vis-grid-row">
                  <?php foreach ($rowCells as $d) echo $cell($d); ?>
                  <?php for ($k = count($rowCells); $k < 3; $k++): ?><span class="dv-vis-cell dv-vis-cell--empty" aria-hidden="true"></span><?php endfor; ?>
                </div>
              <?php endforeach; ?>
            </div>
          <?php endforeach; endif; ?>
        </div>
        <input type="hidden" name="<?= htmlspecialchars($field, ENT_QUOTES) ?>" class="dv-vis-input" value="<?= htmlspecialchars(implode(' ', array_keys($hiddenSet)), ENT_QUOTES) ?>">
      </div>
    <?php
    return ob_get_clean();
};
