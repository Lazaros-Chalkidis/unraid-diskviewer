# Warm the cache on array start so the header badge populates quickly.
(
    while ! mountpoint -q /mnt/user 2>/dev/null; do
        sleep 5
    done
    sleep 5
    mkdir -p /tmp/diskviewer_cache
    chmod 755 /tmp/diskviewer_cache
    php -r "require_once '/usr/local/emhttp/plugins/diskviewer/include/diskviewer_api.php'; DiskViewerEndpoint::writeHeaderCache(DiskViewerEndpoint::buildModel());" >/dev/null 2>&1
) &
